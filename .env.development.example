# ─────────────────────────────────────────────────────────────
# QuantResearch — LOCAL DEVELOPMENT environment template
# Copy to .env for local single-user research.
# Uses the bundled SQLite DB and a single data account. No OAuth, no SaaS.
# ─────────────────────────────────────────────────────────────

# Any non-empty value works locally — do NOT put a real secret here.
FLASK_SECRET_KEY=dev-not-secret

# ── Single Angel One SmartAPI research account ────────────────
PROVIDER_1_ROLE=RESEARCH
PROVIDER_1_API_KEY=
PROVIDER_1_CLIENT_ID=
PROVIDER_1_MPIN=
PROVIDER_1_TOTP_SECRET=

# Local SQLite DB is used automatically (do NOT set DATABASE_URL).

# Keep Fyers off for research-only local runs.
DISABLE_FYERS=1

# ── Optional local conveniences ───────────────────────────────
# Enable one Fyers account locally instead of Angel:
# DISABLE_FYERS=0
# FYERS_APP_ID=
# FYERS_SECRET_KEY=
# FYERS_ACCESS_TOKEN=
# FYERS_REDIRECT_URI=http://127.0.0.1:5000/

# PORT=5000
# AUTO_SCAN_ENABLED_DEFAULT=0
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# FRED_API_KEY=
# NEWS_API_KEY=
