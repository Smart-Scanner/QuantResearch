# ─────────────────────────────────────────────────────────────
# QuantResearch — environment template
# Single-user local quantitative research platform.
# Copy to .env and fill in. Leave optional vars unset to use the
# defaults baked into config.py. (MarketOS SaaS vars intentionally omitted.)
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────
# Flask session signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── Data provider — Angel One SmartAPI (PROVIDER_* is canonical) ──
# At least one RESEARCH provider is needed for live scanning.
# Add PROVIDER_2_*, PROVIDER_3_* blocks for more accounts / throughput.
PROVIDER_1_ROLE=RESEARCH        # RESEARCH | LIVEFEED | EXECUTION
PROVIDER_1_API_KEY=
PROVIDER_1_CLIENT_ID=
PROVIDER_1_MPIN=
PROVIDER_1_TOTP_SECRET=         # base32 TOTP secret
# PROVIDER_1_TYPE=ANGEL         # optional; defaults to ANGEL

# ── Database (optional) ───────────────────────────────────────
# Leave UNSET to use the bundled local SQLite DB (recommended for single-user).
# Only set this if you deliberately want an external Postgres.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# SSL policy (auto): the app picks sslmode from the host — INTERNAL/private hosts
# (Coolify/Docker service names, localhost, *.internal, private IPs) connect with
# sslmode=disable because internal Postgres speaks plaintext (no TLS); EXTERNAL
# managed Postgres (public FQDN: RDS/Supabase/Railway/Neon) uses sslmode=require.
# Override the auto choice for ALL hosts with DB_SSLMODE, or put ?sslmode=... in
# DATABASE_URL (an explicit sslmode in the URL is always respected).
#   e.g. Coolify internal PG:  DATABASE_URL=postgresql://user:pass@<service>:5432/db
#        (auto -> sslmode=disable; no need to set DB_SSLMODE)
# DB_SSLMODE=disable            # force a specific sslmode (disable|require|verify-full|...)

# ── Fyers (optional broker / data) ────────────────────────────
# DISABLE_FYERS=1
# FYERS_APP_ID=
# FYERS_SECRET_KEY=
# FYERS_ACCESS_TOKEN=           # pre-generated token for headless auth
# FYERS_REDIRECT_URI=http://127.0.0.1:5000/   # use YOUR callback; never aismartscan.in

# ── Upstox (optional 3rd RESEARCH provider — historical/fundamentals/news) ──
# Analytics access token = generated once, no daily re-auth (ideal for local).
# When set, Upstox joins the RESEARCH round-robin pool (Angel P1 + P2 + Upstox).
# UPSTOX_ACCESS_TOKEN=
# UPSTOX_API_KEY=
# UPSTOX_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz
# DISABLE_UPSTOX=1            # set to skip Upstox entirely

# ── Zerodha Kite (optional broker / execution) ────────────────
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_REDIRECT_URL=http://127.0.0.1:5000/

# ── Telegram alerts (optional) ────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── News / macro intelligence APIs (optional) ─────────────────
# FRED_API_KEY=
# MARKETAUX_API_KEY=
# NEWS_API_KEY=
# FINNHUB_API_KEY=

# ── Scan / universe tuning (optional; sane defaults in config.py) ──
# USE_UNIVERSE_ENGINE=0
# AUTO_SCAN_ENABLED_DEFAULT=0
# AUTO_SCAN_INTERVAL=60
# MAX_SCAN_WORKERS=6
# SCAN_BATCH_SIZE=50
# FULL_UNIVERSE=0
# GATE_LIMIT=574
# UNIVERSE_MIN_MCAP_CR=1000
# UNIVERSE_MIN_AVG_TURNOVER_CR=10
# UNIVERSE_MIN_AVG_VOLUME=10000
# UNIVERSE_MIN_PRICE=50
# UNIVERSE_MIN_LISTING_DAYS=180

# ── Server (optional) ─────────────────────────────────────────
# PORT=5000
